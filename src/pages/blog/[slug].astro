---
import { getCollection } from "astro:content";
import LayoutPost from "../../layouts/LayoutPost.astro";
import HeaderBlog from "../../components/sections/HeaderBlog.astro";
import LeadForm from "../../components/ui/layouts/LeadForm.astro";
import Footer from "../../components/sections/Footer.astro";
import BlogSchema from "../../components/BlogSchema.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}
const { post } = Astro.props;
const { Content } = await post.render();
---

<LayoutPost
  description={post.data.description}
  title={post.data.title}
  post={post}
>
  <HeaderBlog />
  <section>
    <article
      class="prose
      px-3
      py-5
      w-full
      md:max-w-2xl
      xl:max-w-4xl
      mx-auto
      prose-time:text-xs
      prose-h2:text-xl
      prose-p:text-gray-600
    prose-a:text-blue-600
      prose-a:no-underline
    prose-code:bg-gray-100
      prose-code:px-1
    prose-pre:bg-black
    prose-pre:text-white
      prose-img:rounded-md
      prose-img:md:max-w-[60%]
      prose-img:mx-auto
      max-w-none"
    >
      <h1 class="text-3xl">
        {post.data.title}
      </h1>
      <p class="text-sm italic">
        <time
          datetime={`${post.data.pubDate.getFullYear()}/0${post.data.pubDate.getMonth() + 1}/${post.data.pubDate.getDate()}`}
          >Publicado em {
            `${post.data.pubDate.getDate()}/0${post.data.pubDate.getMonth() + 1}/${post.data.pubDate.getFullYear()}`
          }</time
        >
        <br />
        <span>Autor: {post.data.author}</span>
      </p>
      <Image
        src={post.data.cover}
        alt={post.data.title}
        class="w-full md:max-w-[60%]"
        loading="eager"
        format="webp"
        quality="mid"
      />

      <Content />
    </article>
  </section>

  <section class="pt-7">
    <h2
      class="text-primary text-center text-2xl md:text-3xl lg:text-5xl font-extrabold px-7 md:px-40"
    >
      Quer uma Consultoria Gratuita?
    </h2>

    <p
      class="text-center px-3 py-7 pb-7 md:px-40 xl:pb-16 md:text-center lg:text-xl"
    >
      Se você quer transformar seu site em uma máquina de captação de clientes,
      nós vamos analisar seu site atual (ou a falta de um), seu posicionamento
      no Google, o que seus concorrentes estão fazendo e <strong
        >entraremos em contato com você</strong
      >.
    </p>

    <div class="w-full px-3">
      <LeadForm />
    </div>
  </section>
  <Footer />
</LayoutPost>
